# Pantheon frontend – environment variable reference
# Copy this file to .env and fill in the values for local development.
# In Cloudflare Pages, set these in Project Settings → Environment Variables.

# Base URL of the Pantheon backend API.
# Local development:
VITE_API_URL=http://127.0.0.1:8000
# Production (replace with your actual Koyeb URL):
# VITE_API_URL=https://your-app-name.koyeb.app
