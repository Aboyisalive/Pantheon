# ─────────────────────────────────────────────────────────────────
# Pantheon – environment variable reference
# Copy this file to .env and fill in the values before running
# the backend locally or via docker-compose.
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL connection string used by SQLAlchemy.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://user:password@localhost:5432/pantheon

# ── Security ──────────────────────────────────────────────────────
# Long random string used to sign JWT tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_long_random_string

# ── AI Provider ───────────────────────────────────────────────────
# API key for the Google GenAI / OpenAI-compatible service.
OPENAI_API_KEY=your_openai_or_gemini_api_key_here

# ── CORS / Frontend URL ───────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# For local development this is usually http://localhost:5173.
# In production add your Cloudflare Pages domain, e.g.:
#   FRONTEND_URL=http://localhost:5173,https://pantheon.pages.dev
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────────
# Frontend (Vite / React) – only needed when running locally.
# In Cloudflare Pages set this in the project's environment variables.
# ─────────────────────────────────────────────────────────────────

# Base URL of the backend API.
# Locally: http://127.0.0.1:8000
# Production: https://your-app-name.koyeb.app
VITE_API_URL=http://127.0.0.1:8000
